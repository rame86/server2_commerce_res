generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["res"]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model events {
  event_id        Int            @id @default(autoincrement())
  title           String         @db.VarChar(255)
  artist_name     String?        @db.VarChar(100)
  event_type      String?        @db.VarChar(50)
  price           Int
  total_capacity  Int
  available_seats Int
  venue           String         @db.VarChar(255)
  address         String         @db.VarChar(500)
  event_date      DateTime       @db.Timestamptz(6)
  open_time       DateTime       @db.Timestamptz(6)
  close_time      DateTime       @db.Timestamptz(6)
  version         Int            @default(0)
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  reservations    reservations[]

  @@index([open_time, close_time], map: "idx_events_open_close")
  @@schema("res")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reservations {
  reservation_id String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id       Int
  member_id      BigInt
  ticket_count   Int
  total_price    Int
  ticket_code    String    @unique @db.VarChar(50)
  booked_at      DateTime? @default(now()) @db.Timestamptz(6)
  status         String?   @default("PENDING") @db.VarChar(20)
  events         events    @relation(fields: [event_id], references: [event_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([event_id], map: "idx_reservations_event")
  @@index([member_id], map: "idx_reservations_user")
  @@schema("res")
}
